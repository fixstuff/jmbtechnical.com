---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'JMB Technical - Industrial Automation, SCADA, and Controls Engineering. PLC programming, SCADA integration, custom software, and the GOPLC runtime.', ogImage = '/images/showcase/goplc-web-ide.png' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://jmbtechnical.com');
const fullTitle = `${title} | JMB Technical`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="PLC runtime, IEC 61131-3, structured text, industrial automation, SCADA, Go, Modbus, EtherNet/IP, OPC UA, BACnet, FINS, DNP3, IIoT, MCP server, AI automation" />
    <meta name="author" content="JMB Technical" />
    <link rel="canonical" href={canonicalURL.toString()} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.toString()} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, 'https://jmbtechnical.com').toString()} />
    <meta property="og:site_name" content="JMB Technical" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, 'https://jmbtechnical.com').toString()} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{fullTitle}</title>
  </head>
  <body class="bg-surface text-text min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GoplcNav from '../../components/GoplcNav.astro';
import Screenshot from '../../components/Screenshot.astro';
---

<BaseLayout title="GOPLC Features" description="Deep dive into GOPLC's capabilities: web IDE, AI code generation, boss/minion clustering, 14+ protocol drivers, step debugger, Node-RED integration, and more.">
  <GoplcNav />

  <!-- Header -->
  <section class="bg-gray-950 text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="inline-block bg-accent/10 text-accent px-4 py-1.5 rounded-full text-sm font-medium mb-6 border border-accent/20">
          Features
        </div>
        <h1 class="text-4xl md:text-5xl font-extrabold mb-6">
          Every Feature.<br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#00ADD8] to-[#4ec9b0]">Every Detail.</span>
        </h1>
        <p class="text-xl text-gray-400 leading-relaxed">
          GOPLC isn't a proof of concept. It's 180,000+ lines of production-grade Go code with capabilities that don't exist anywhere else in industrial automation.
        </p>
      </div>
    </div>
  </section>

  <!-- Dashboard Overview -->
  <section id="dashboard" class="py-24 scroll-mt-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-block bg-accent/10 text-accent px-3 py-1 rounded-full text-sm font-medium mb-4">
            At a Glance
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-primary-dark mb-6">
            GOPLC Dashboard
          </h2>
          <p class="text-text-light mb-6 leading-relaxed">
            The dashboard gives you an instant overview of your entire runtime &mdash; state, uptime, task performance, program inventory, memory usage, and I/O driver status. All live, all in the browser.
          </p>
          <p class="text-text-light mb-8 leading-relaxed">
            Task performance metrics show scan counts, average and max scan times, and error counts for every running task. Click through to the IDE to drill into any program or variable.
          </p>
          <ul class="space-y-3">
            <li class="flex items-center gap-3 text-sm text-text">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Runtime state, uptime, and memory at a glance
            </li>
            <li class="flex items-center gap-3 text-sm text-text">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Per-task scan performance with avg/max timing
            </li>
            <li class="flex items-center gap-3 text-sm text-text">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Program inventory with line counts and task assignments
            </li>
          </ul>
        </div>
        <Screenshot src="/images/showcase/goplc-dashboard.png" alt="GOPLC Dashboard showing runtime state, task performance metrics, program inventory, and memory usage" caption="GOPLC Dashboard &mdash; runtime state, task performance, programs, and memory at a glance" />
      </div>
    </div>
  </section>

  <!-- Web IDE -->
  <section id="ide" class="py-24 bg-gray-50 scroll-mt-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="order-2 md:order-1">
          <Screenshot src="/images/showcase/goplc-ide-online.png" alt="GOPLC Web IDE with Monaco editor showing Structured Text code with live variable values inline, syntax highlighting, and online mode active" caption="Web IDE with online mode &mdash; live variable values appear inline next to code" />
        </div>
        <div class="order-1 md:order-2">
          <div class="inline-block bg-[#00ADD8]/10 text-[#00ADD8] px-3 py-1 rounded-full text-sm font-medium mb-4">
            Development
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-primary-dark mb-6">
            Web-Based IDE with Online Mode
          </h2>
          <p class="text-text-light mb-6 leading-relaxed">
            The same Monaco editor engine that powers VS Code, running in your browser. Full IEC 61131-3 Structured Text with syntax highlighting, autocomplete, code folding, and multi-cursor editing. The help panel shows function signatures and examples as you type.
          </p>
          <p class="text-text-light mb-8 leading-relaxed">
            Enter online mode and live variable values appear inline next to every declaration and assignment &mdash; color-coded by data type, updating in real time via WebSocket. Multiple users can monitor simultaneously from any browser.
          </p>
          <ul class="space-y-3">
            <li class="flex items-center gap-3 text-sm text-text">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Autocomplete for 1,600+ built-in functions
            </li>
            <li class="flex items-center gap-3 text-sm text-text">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Real-time inline variable values via WebSocket
            </li>
            <li class="flex items-center gap-3 text-sm text-text">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Hot reload &mdash; deploy without stopping the runtime
            </li>
            <li class="flex items-center gap-3 text-sm text-text">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Multi-user simultaneous access from any device
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Step Debugger -->
  <section id="debugger" class="py-24 scroll-mt-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-block bg-[#00ADD8]/10 text-[#00ADD8] px-3 py-1 rounded-full text-sm font-medium mb-4">
            Debugging
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-primary-dark mb-6">
            Statement-Level Step Debugger
          </h2>
          <p class="text-text-light mb-6 leading-relaxed">
            Traditional PLCs offer limited debugging &mdash; maybe online monitoring of variable values. GOPLC brings modern software debugging to industrial control. Set breakpoints on any line. Step through code statement by statement. The current execution line is highlighted, and you can inspect and modify variables in real time.
          </p>
          <p class="text-text-light mb-8 leading-relaxed">
            Ten dedicated API endpoints power the debugger, with multi-task awareness so you can debug across concurrent PLC tasks. All running in a standard web browser &mdash; no vendor software required.
          </p>
          <ul class="space-y-3">
            <li class="flex items-center gap-3 text-sm text-text">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Breakpoints with yellow execution highlight
            </li>
            <li class="flex items-center gap-3 text-sm text-text">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Step into, step over, step out, continue
            </li>
            <li class="flex items-center gap-3 text-sm text-text">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Live variable inspection and modification
            </li>
            <li class="flex items-center gap-3 text-sm text-text">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Multi-task awareness across concurrent programs
            </li>
          </ul>
        </div>
        <Screenshot src="/images/showcase/goplc-debugger.png" alt="GOPLC step debugger with breakpoint hit on line showing yellow execution highlight, live variable values, and debug controls" caption="Step debugger &mdash; breakpoint hit with execution highlight and live variable values" />
      </div>
    </div>
  </section>

  <!-- AI Code Generation -->
  <section id="ai" class="py-24 bg-gray-50 scroll-mt-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="order-2 md:order-1">
          <Screenshot src="/images/showcase/goplc-ai-assistant.png" alt="GOPLC AI Assistant showing Claude integration with natural language prompt and AI response listing ST code generation, protocol configuration, HMI creation, and Node-RED flow building capabilities" caption="AI Assistant &mdash; Claude integration for ST code generation, protocol config, and more" />
        </div>
        <div class="order-1 md:order-2">
          <div class="inline-block bg-[#4ec9b0]/10 text-[#4ec9b0] px-3 py-1 rounded-full text-sm font-medium mb-4">
            Artificial Intelligence
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-primary-dark mb-6">
            AI-Powered Code Generation &amp; Agentic Control
          </h2>
          <p class="text-text-light mb-6 leading-relaxed">
            Describe what you want in plain English. GOPLC's AI generates working Structured Text code using the full registry of 1,600+ built-in functions &mdash; not generic code that references functions that don't exist, but code that actually compiles and runs.
          </p>
          <p class="text-text-light mb-8 leading-relaxed">
            The AI assistant can write ST programs, configure protocol drivers, create HMI pages, build Node-RED flows, debug existing code, and even explain GOPLC features. Beyond code generation, the <strong>agentic control loop</strong> lets AI operate the PLC directly through 12 built-in tools.
          </p>
          <div class="bg-white rounded-lg border border-gray-200 p-6 mb-6">
            <h4 class="font-bold text-primary-dark mb-3 text-sm">Supported AI Providers</h4>
            <div class="grid grid-cols-3 gap-4 text-center text-sm">
              <div>
                <div class="font-semibold text-primary-dark">Claude</div>
                <div class="text-text-light text-xs">Best for complex logic</div>
              </div>
              <div>
                <div class="font-semibold text-primary-dark">OpenAI</div>
                <div class="text-text-light text-xs">Strong general-purpose</div>
              </div>
              <div>
                <div class="font-semibold text-primary-dark">Ollama</div>
                <div class="text-text-light text-xs">Local / air-gapped</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Monitor & Variables -->
  <section id="monitor" class="py-24 scroll-mt-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-block bg-[#4ec9b0]/10 text-[#4ec9b0] px-3 py-1 rounded-full text-sm font-medium mb-4">
            Monitoring
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-primary-dark mb-6">
            Monitor &amp; Variable Explorer
          </h2>
          <p class="text-text-light mb-6 leading-relaxed">
            The Monitor tab gives you multiple views into the running system. The Tasks view shows every running task with scan counts, average and max scan times, and error counts. The Variables view expands each task into its program tree with every variable visible and watchable.
          </p>
          <p class="text-text-light mb-8 leading-relaxed">
            The Watch List lets you pin specific variables from any program for continuous monitoring. The Tags view provides a flat table of all variables across all programs with filtering, sorting, and live values.
          </p>
          <ul class="space-y-3">
            <li class="flex items-center gap-3 text-sm text-text">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Task tree with expandable programs and variables
            </li>
            <li class="flex items-center gap-3 text-sm text-text">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Watch List for pinning variables across programs
            </li>
            <li class="flex items-center gap-3 text-sm text-text">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Tags view with flat table, filtering, and sorting
            </li>
          </ul>
        </div>
        <div class="space-y-6">
          <Screenshot src="/images/showcase/goplc-monitor-variables-new.png" alt="GOPLC Monitor showing task tree with P2Task, ARDTask, and P2Mon expanded to show program variables, plus Watch List with pinned variables" caption="Variable explorer with task tree and Watch List" />
          <Screenshot src="/images/showcase/goplc-tags-variables.png" alt="GOPLC Tags view showing flat variable table with program, variable name, type, and live values" caption="Tags view &mdash; all variables in a searchable, sortable table" />
        </div>
      </div>
    </div>
  </section>

  <!-- Boss/Minion Clustering -->
  <section id="clustering" class="py-24 bg-gray-50 scroll-mt-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="order-2 md:order-1">
          <Screenshot src="/images/showcase/goplc-monitor-tasks.png" alt="GOPLC Monitor showing 3 running tasks (P2Task at 50ms, ARDTask at 2000ms, P2Mon at 1000ms) with scan counts, average and max scan times" caption="Monitor &mdash; 3 concurrent tasks running at different scan rates with performance metrics" />
        </div>
        <div class="order-1 md:order-2">
          <div class="inline-block bg-[#00ADD8]/10 text-[#00ADD8] px-3 py-1 rounded-full text-sm font-medium mb-4">
            Architecture
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-primary-dark mb-6">
            Boss/Minion Clustering
          </h2>
          <p class="text-text-light mb-6 leading-relaxed">
            Traditional PLCs are islands. GOPLC breaks this paradigm with its Boss/Minion architecture &mdash; a central Boss coordinates thousands of Minion instances, each executing control logic independently at their own scan rates.
          </p>
          <p class="text-text-light mb-8 leading-relaxed">
            Tested at scale with 10,000+ concurrent PLC instances and 620,000+ aggregate scans per second. Linear scaling to 500 minions at 95%+ efficiency.
          </p>
          <div class="bg-gray-900 rounded-lg p-6">
            <h4 class="font-bold text-white mb-4 text-sm">Benchmark Results (31 cores)</h4>
            <div class="space-y-3 text-sm">
              <div class="flex justify-between">
                <span class="text-gray-400">Throughput improvement</span>
                <span class="text-accent font-bold">10.4x</span>
              </div>
              <div class="border-t border-gray-700"></div>
              <div class="flex justify-between">
                <span class="text-gray-400">Aggregate scans/sec</span>
                <span class="text-[#00ADD8] font-bold">620,949</span>
              </div>
              <div class="border-t border-gray-700"></div>
              <div class="flex justify-between">
                <span class="text-gray-400">DataLayer latency (avg)</span>
                <span class="text-[#4ec9b0] font-bold">1.7 &micro;s</span>
              </div>
              <div class="border-t border-gray-700"></div>
              <div class="flex justify-between">
                <span class="text-gray-400">Docker overhead</span>
                <span class="text-green-400 font-bold">ZERO</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Fleet Management -->
  <section id="fleet" class="py-24 scroll-mt-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-block bg-accent/10 text-accent px-3 py-1 rounded-full text-sm font-medium mb-4">
            Management
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-primary-dark mb-6">
            Fleet Management
          </h2>
          <p class="text-text-light mb-6 leading-relaxed">
            When you're running dozens or thousands of GOPLC instances across multiple sites, you need centralized visibility. Fleet Management uses mDNS auto-discovery to find every instance on the network, shows their version, health status, project hash, and role &mdash; all in a single table.
          </p>
          <p class="text-text-light mb-8 leading-relaxed">
            Push configurations to individual nodes or bulk-deploy across your entire fleet. Drift detection compares project hashes across all healthy nodes to catch configuration divergence. Any GOPLC instance can become a fleet manager &mdash; just enable it in config.
          </p>
          <ul class="space-y-3">
            <li class="flex items-center gap-3 text-sm text-text">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              mDNS auto-discovery &amp; persistent node registry
            </li>
            <li class="flex items-center gap-3 text-sm text-text">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Bulk push &amp; atomic deploy across the fleet
            </li>
            <li class="flex items-center gap-3 text-sm text-text">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Drift detection across all healthy nodes
            </li>
          </ul>
        </div>
        <Screenshot src="/images/showcase/goplc-fleet-management.png" alt="GOPLC Fleet Management showing 6 discovered nodes via mDNS with Node ID, host/port, role, status, version, hash, and IDE/Config action buttons" caption="Fleet Management &mdash; 6 nodes discovered via mDNS with health, version, and hash" />
      </div>
    </div>
  </section>

  <!-- Project Snapshots -->
  <section id="snapshots" class="py-24 bg-gray-50 scroll-mt-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="order-2 md:order-1">
          <Screenshot src="/images/showcase/goplc-snapshots.png" alt="GOPLC Project Snapshots dialog showing snapshot history with hash, project name, date, source (import/download), size, and Export/Restore/Delete actions" caption="Project Snapshots &mdash; version history with restore, export, and timeline views" />
        </div>
        <div class="order-1 md:order-2">
          <div class="inline-block bg-[#4ec9b0]/10 text-[#4ec9b0] px-3 py-1 rounded-full text-sm font-medium mb-4">
            Version Control
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-primary-dark mb-6">
            Project Snapshots
          </h2>
          <p class="text-text-light mb-6 leading-relaxed">
            Every project download and import is automatically captured as a snapshot &mdash; stored with SQLite metadata and gzip compression. Browse your project history, restore any previous version, or export snapshots as .goplc files.
          </p>
          <p class="text-text-light mb-8 leading-relaxed">
            The fleet manager automatically collects snapshots from remote nodes when their project hash changes, giving you a centralized backup of every configuration change across your entire deployment.
          </p>
          <ul class="space-y-3">
            <li class="flex items-center gap-3 text-sm text-text">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Auto-save on every download and import
            </li>
            <li class="flex items-center gap-3 text-sm text-text">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Restore, export, and timeline views
            </li>
            <li class="flex items-center gap-3 text-sm text-text">

            <div class="flex items-baseline gap-1">
              <span class="text-4xl font-extrabold text-primary-dark">$49</span>
            </div>
            <p class="text-text-light text-xs mt-1">Campaign pricing &bull; 1 seat</p>
            <p class="text-red-500 text-xs font-semibold mt-1">90% off retail</p>
          </div>
          <ul class="space-y-3 mb-8 flex-1 text-sm text-text">

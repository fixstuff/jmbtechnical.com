---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GoplcNav from '../../components/GoplcNav.astro';
---

<BaseLayout title="GOPLC Pricing — Indiegogo Launch" description="GOPLC Indiegogo launch pricing: lifetime licenses from $49. Limited time early-backer tiers available now.">
  <GoplcNav />

  <!-- Header -->
  <section class="bg-gray-950 text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-6">
        Simple, Transparent Pricing
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed">
        One product. No add-on modules. No annual maintenance fees.
        Every license includes every feature, every protocol driver, and every update.
      </p>
    </div>
  </section>

  <!-- Indiegogo Banner -->
  <section class="relative bg-gradient-to-r from-orange-500 via-red-500 to-pink-500 py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="text-white">
        <div class="text-sm font-bold uppercase tracking-widest mb-2">Limited Time &mdash; Indiegogo Launch Pricing</div>
        <div class="text-3xl md:text-4xl font-extrabold">Up to 90% off retail pricing</div>
        <p class="text-white/80 mt-2 text-lg">GOPLC is available exclusively through Indiegogo during the campaign. Back now to lock in these prices.</p>
      </div>
    </div>
  </section>

  <!-- Old Pricing — Crossed Out -->
  <section class="py-16 bg-gray-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="relative rounded-2xl border-2 border-dashed border-gray-300 bg-white p-10 opacity-50">
        <!-- Big X overlay -->
        <div class="absolute inset-0 flex items-center justify-center pointer-events-none z-10">
          <svg class="w-full h-full text-red-500/30" viewBox="0 0 100 100" preserveAspectRatio="none">
            <line x1="0" y1="0" x2="100" y2="100" stroke="currentColor" stroke-width="2" vector-effect="non-scaling-stroke" />
            <line x1="100" y1="0" x2="0" y2="100" stroke="currentColor" stroke-width="2" vector-effect="non-scaling-stroke" />
          </svg>
        </div>
        <div class="text-center">
          <p class="text-sm text-gray-400 uppercase tracking-wide font-bold mb-4">Previous Retail Pricing</p>
          <div class="flex flex-wrap justify-center gap-8 text-gray-400">
            <div>
              <span class="text-3xl font-extrabold line-through">$500</span>
              <span class="text-sm block">Standard</span>
            </div>
            <div>
              <span class="text-3xl font-extrabold line-through">$400</span>
              <span class="text-sm block">Volume</span>
            </div>
            <div>
              <span class="text-3xl font-extrabold line-through">Custom</span>
              <span class="text-sm block">Enterprise</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Indiegogo Pricing Cards -->
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-primary-dark mb-4">Indiegogo Launch Tiers</h2>
        <p class="text-lg text-text-light max-w-2xl mx-auto">
          These prices are only available during the Indiegogo campaign. Every tier includes all features, all drivers, and all future updates.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">

        <!-- Signal -->

---
import BaseLayout from '../../layouts/BaseLayout.astro';

const whitepapers = [
  {
    title: 'The Scenario Was Not Hypothetical - The Claude Code Incident as a Live Case Study',
    description: 'Follow-up to "Functional Equivalence and the Limits of Law." On March 31, 2026, Anthropic accidentally shipped 512,000 lines of proprietary Claude Code source via a misconfigured npm source map. Within 24 hours: Python and Rust rewrites, 100,000 GitHub stars, IPFS upload beyond DMCA reach. Every prediction from the original paper — source map exposure, AI-assisted language chain rewrite, clean-room defense, jurisdictional fracture — manifested exactly as analyzed.',
    date: 'April 2026',
    version: '1.0',
    tags: ['AI Policy', 'Intellectual Property', 'Legal Analysis', 'Case Study'],
    pdf: '/whitepapers/ip_ai_whitepaper2.pdf',
    markdown: '/whitepapers/ip-ai-whitepaper2/',
  },
  {
    title: 'Functional Equivalence and the Limits of Law - AI, Copyright, and Patent Law',
    description: 'How artificial intelligence will fundamentally disrupt intellectual property law. Traces the chain from AI-enabled functional reimplementation through the collapse of copyright\'s idea-expression dichotomy, patent law\'s structural failures, and trade secret limitations — to national security implications and a proposed framework for legal reform centered on functional equivalence as a cognizable harm.',
    date: 'April 2026',
    version: '1.0',
    tags: ['AI Policy', 'Intellectual Property', 'Legal Analysis', 'National Security'],
    pdf: '/whitepapers/ip_ai_whitepaper.pdf',
    markdown: '/whitepapers/ip-ai-whitepaper/',
  },
  {
    title: 'The Optimus Network - Distributed Infrastructure & Vertical Integration',
    description: 'Independent structural analysis of Tesla\'s humanoid robot economics. Covers the subscriber-funded distributed compute network model, planetary-scale behavioral data asset valuation, defense sector implications, supply chain security risks, and adversarial ML attack vectors. Three-part analysis spanning commercial network economics, data monetization, and the military dimension.',
    date: 'March 2026',
    version: '1.0',
    tags: ['Strategic Analysis', 'Robotics', 'Economics', 'Defense'],
    pdf: '/whitepapers/optimus_network_analysis.pdf',
    markdown: '/whitepapers/optimus-network-analysis/',
  },
  {
    title: 'Humanoid Robotics - The Robot Control Problem',
    description: '12-runtime clustered architecture for Optimus-class humanoid robots. Maps industrial PLC scan-cycle scheduling to 52+ DOF servo control with 1ms–100ms scan rate span. Measured 94–99% CPU idle running 7 protocol stacks simultaneously on ARM64. Native AI integration via MCP server bridge. Includes RTOS comparison with measured data.',
    date: 'March 2026',
    version: '1.1',
    tags: ['Robotics', 'Real-Time', 'AI Integration', 'ARM64'],
    pdf: '/whitepapers/GoPLC_Humanoid_Robotics_Whitepaper.pdf',
    markdown: '/whitepapers/humanoid-robotics/',
  },
  {
    title: 'Clustering - Distributed Real-Time PLC Performance',
    description: '10.4x throughput improvement, 620,949 aggregate scans/sec, linear scaling to 500+ minions. Covers the boss/minion distributed architecture that breaks the monolithic PLC paradigm, achieving sub-50-microsecond scan times on commodity hardware.',
    date: 'February 2026',
    version: '1.0',
    tags: ['Clustering', 'Real-Time', 'Benchmarks'],
    pdf: '/whitepapers/whitepaper-clustering.pdf',
    markdown: '/whitepapers/clustering/',
  },
  {
    title: 'Datacenter Gateway - Universal Protocol Gateway',
    description: 'Three-tier DC hierarchy, 12 protocol drivers, dual-path MQTT + DNP3 store-and-forward, redundancy strategies, and AI-assisted commissioning. GOPLC as a universal protocol gateway normalizing Modbus, SNMP, BACnet, EtherNet/IP and more into unified OPC UA/MQTT/DNP3 northbound feeds.',
    date: 'January 2026',
    version: '1.1',
    tags: ['Data Center', 'Protocol Gateway', 'BMS/EPMS'],
    pdf: '/whitepapers/whitepaper-datacenter-gateway.pdf',
    markdown: '/whitepapers/datacenter-gateway/',
  },
  {
    title: 'DC Simulation - Hardware Gateway Architecture',
    description: 'A full-stack, protocol-native digital twin for hyperscale datacenter operations. 11 device simulators, 6 gateway blueprints, scale estimates from 50 MW to 1 GW, ctrlX CORE edge SBC deployment, and full cost modeling.',
    date: 'February 2026',
    version: '1.0',
    tags: ['Data Center', 'Digital Twin', 'Hardware'],
    pdf: '/whitepapers/WHITEPAPER_DC_SIMULATION_HARDWARE.pdf',
    markdown: '/whitepapers/dc-simulation-hardware/',
  },
  {
    title: 'DC Simulation - Virtualized Gateway Architecture',
    description: 'Eliminating edge hardware with server-based gateways and routed VLANs. 51-66% total cost reduction vs hardware gateways, migration paths from hardware to virtualized, and IEC 62443 security considerations.',
    date: 'February 2026',
    version: '1.0',
    tags: ['Data Center', 'Virtualization', 'Cost Reduction'],
    pdf: '/whitepapers/WHITEPAPER_DC_SIMULATION_VIRTUAL.pdf',
    markdown: '/whitepapers/dc-simulation-virtual/',
  },
];

const reports = [
  {
    title: 'Water Treatment Plant Simulation - Performance Report',
    description: 'Monolith vs in-process cluster architecture comparison. 37 programs originally averaging 130ms on the monolith, since optimized to 22ms scan time through GOPLC engine improvements. The 10-node cluster achieves 13x faster execution with zero watchdog faults.',
    date: 'February 2026',
    tags: ['Performance', 'Water Treatment', 'Benchmarks'],
    pdf: '/whitepapers/WTP_Performance_Report.pdf',
    markdown: '/whitepapers/wtp-performance-report/',
  },
];
---

<BaseLayout title="White Papers & Reports" description="Technical white papers and performance reports on GOPLC distributed PLC architecture, datacenter gateway design, and industrial simulation.">
  <!-- Hero -->
  <section class="bg-primary-dark text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-6">White Papers & Reports</h1>
        <p class="text-xl text-gray-300 leading-relaxed">
          In-depth technical documents covering distributed PLC architecture, datacenter infrastructure, industrial simulation, AI policy, and emerging technology analysis.
        </p>
      </div>
    </div>
  </section>

  <!-- White Papers -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-primary-dark mb-12">White Papers</h2>
      <div class="grid gap-8">
        {whitepapers.map((paper) => (
          <div class="bg-white border border-gray-100 rounded-xl p-8 hover:shadow-lg transition-shadow">
            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
              <div class="flex-1">
                <div class="flex flex-wrap gap-2 mb-3">
                  {paper.tags.map((tag) => (
                    <span class="bg-accent/10 text-accent text-xs font-semibold px-2.5 py-0.5 rounded-full">{tag}</span>
                  ))}
                </div>
                <h3 class="text-xl font-bold text-primary-dark mb-2">{paper.title}</h3>
                <p class="text-text-light text-sm leading-relaxed mb-3">{paper.description}</p>
                <div class="text-xs text-gray-400">
                  {paper.date} &middot; Version {paper.version}
                </div>
              </div>
              <div class="flex flex-col gap-2 md:flex-shrink-0 md:ml-8">
                <a href={paper.pdf} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-accent hover:bg-accent-dark text-primary-dark font-semibold px-5 py-2.5 rounded-lg transition-colors text-sm">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm-1 2l5 5h-5V4zM6 20V4h5v7h7v9H6z"/></svg>
                  Download PDF
                </a>
                <a href={paper.markdown} class="inline-flex items-center gap-2 border border-gray-300 hover:border-accent hover:text-accent px-5 py-2.5 rounded-lg transition-colors text-sm text-text">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm-1 2l5 5h-5V4zM6 20V4h5v7h7v9H6z"/></svg>
                  Read Online
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Reports -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-primary-dark mb-12">Technical Reports</h2>
      <div class="grid gap-8">
        {reports.map((report) => (
          <div class="bg-white border border-gray-100 rounded-xl p-8 hover:shadow-lg transition-shadow">
            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
              <div class="flex-1">
                <div class="flex flex-wrap gap-2 mb-3">
                  {report.tags.map((tag) => (
                    <span class="bg-primary-dark/10 text-primary-dark text-xs font-semibold px-2.5 py-0.5 rounded-full">{tag}</span>
                  ))}
                </div>
                <h3 class="text-xl font-bold text-primary-dark mb-2">{report.title}</h3>
                <p class="text-text-light text-sm leading-relaxed mb-3">{report.description}</p>
                <div class="text-xs text-gray-400">{report.date}</div>
              </div>
              <div class="flex flex-col gap-2 md:flex-shrink-0 md:ml-8">
                <a href={report.pdf} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-accent hover:bg-accent-dark text-primary-dark font-semibold px-5 py-2.5 rounded-lg transition-colors text-sm">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm-1 2l5 5h-5V4zM6 20V4h5v7h7v9H6z"/></svg>
                  Download PDF
                </a>
                <a href={report.markdown} class="inline-flex items-center gap-2 border border-gray-300 hover:border-accent hover:text-accent px-5 py-2.5 rounded-lg transition-colors text-sm text-text">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm-1 2l5 5h-5V4zM6 20V4h5v7h7v9H6z"/></svg>
                  Read Online
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
